# SkillLedger License Verification - Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=SkillLedger Licenses
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=10000

# Database (Render will auto-populate this)
DATABASE_URL=postgresql://user:password@localhost:5432/skilledger_licenses

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs (State Boards)
NURSYS_API_KEY=your-nursys-api-key-here
NURSYS_API_URL=https://www.nursys.com/api/v1

# AWS S3 (for screenshot storage) - Optional
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=skilledger-screenshots

# SendGrid (for email alerts) - Optional
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@skilledger.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Background Workers (Optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
ENABLE_DAILY_CHECKS=true
MONITORING_CHECK_HOUR=2

# CORS
CORS_ORIGINS=["*"]
